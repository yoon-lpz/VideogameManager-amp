@page
@model VideoGameManager.Pages.Stats.IndexModel
@{
    ViewData["Title"] = "Stats";
}

<div style="font-family: 'Segoe UI'; max-width: 900px; margin: 30px auto">
    <h1 style="color: #444; border-bottom: 3px solid #88d8c0; padding-bottom: 10px; margin-bottom: 30px;">
        Quick Insights
    </h1>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        
        <div style="border: 2px solid #88d8c0; border-radius: 8px; background: white; overflow: hidden;">
            <div style="background: #88d8c0; color: white; padding: 10px; font-weight: bold; text-align: center;">TOP 5 RATED</div>
            <div style="padding: 15px;">
                @foreach (var game in Model.Top5Games)
                {
                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #eee; padding: 8px 0;">
                        <span><strong>@game.Title</strong> <small style="color:#999">(@game.Developer?.Name)</small></span>
                        <span style="color: #88d8c0; font-weight: bold;">@game.Score</span>
                    </div>
                }
            </div>
        </div>

        <div style="border: 2px solid #88d8c0; border-radius: 8px; background: white; overflow: hidden;">
            <div style="background: #88d8c0; color: white; padding: 10px; font-weight: bold; text-align: center;">BY DECADE</div>
            <div style="padding: 15px;">
                @foreach (var item in Model.GamesByDecade)
                {
                    var percentage = Model.AllGames.Count > 0
                         ? (item.Count * 100.0 / Model.AllGames.Count).ToString("0", System.Globalization.CultureInfo.InvariantCulture)
                         : "0";
                    <div style="display: flex; align-items: center; margin-bottom: 12px;">
                        <span style="width: 60px; font-weight: bold;">@item.Decade's</span>
                        <div style="flex-grow: 1; background: #f0f0f0; height: 12px; border-radius: 6px; margin: 0 10px;">
                            <div style="background: #88d8c0; width: @(percentage)%; height: 100%; border-radius: 6px;"></div>
                        </div>
                        <span style="font-weight: bold;">@item.Count (@percentage%)</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div style="border: 2px solid #88d8c0; border-radius: 8px; background: white; overflow: hidden;">
        <div style="background: #88d8c0; padding: 15px; border-bottom: 1px solid #88d8c0;">
            <form method="get" style="display: flex; align-items: center; gap: 15px;">
                <label style="font-weight: bold; color: white;">Browse by Genre:</label>
                <select asp-for="SelectedGenre" asp-items="Model.Genres" onchange="this.form.submit()"
                        style="padding: 8px 15px; border-radius: 20px; border: 1px solid #88d8c0; outline: none;">
                    <option value="">View All</option>
                </select>
            </form>
        </div>

        <div style="padding: 20px;">
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 15px;">
                @foreach (var game in Model.FilteredGames)
                {
                    <div style="padding: 15px; border: 1px solid #eee; border-radius: 8px; text-align: center;">
                        <div style="font-weight: bold; color: #444;">@game.Title</div>
                        <div style="color: #88d8c0; font-size: 14px; margin-top: 5px;">★ @game.Score</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div style="border: 2px solid #88d8c0; border-radius: 8px; background: white; overflow: hidden; margin-bottom: 30px;">
        <div style="background: #88d8c0; color: white; padding: 10px; font-weight: bold; text-align: center;">
            DEVELOPER PERFORMANCE (AVG SCORE)
        </div>
        <div style="padding: 15px;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid #eee; text-align: left; color: #666;">
                        <th style="padding: 10px;">Developer</th>
                        <th style="padding: 10px; text-align: center;">Games</th>
                        <th style="padding: 10px; text-align: right;">Average Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dev in Model.AvgPerDev)
                    {
                        <tr style="border-bottom: 1px solid #f9f9f9;">
                            <td style="padding: 10px; font-weight: bold;">@dev.Name</td>
                            <td style="padding: 10px; text-align: center; color: #999;">@dev.GameCount</td>
                            <td style="padding: 10px; text-align: right; color: #88d8c0; font-weight: bold;">
                                @dev.AvgScore.ToString("F2")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div style="border: 2px solid #88d8c0; border-radius: 8px; background: white; overflow: hidden; margin-bottom: 30px;">
        <div style="background: #88d8c0; color: white; padding: 15px; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-weight: bold;">PRODUCTIVE DEVELOPERS</span>
            <form method="get" style="display: flex; align-items: center; gap: 10px;">
                <label style="font-size: 0.8em;">Min. games:</label>
                <input type="number" asp-for="Threshold" min="0"
                       style="width: 60px; border-radius: 4px; border: none; padding: 2px 5px;"
                       onchange="this.form.submit()" />
            </form>
        </div>
        <div style="padding: 15px;">
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                @foreach (var dev in Model.ProductiveDevs)
                {
                    <div style="background: #f0fdf9; border: 1px solid #88d8c0; padding: 8px 15px; border-radius: 20px; display: flex; align-items: center; gap: 8px;">
                        <span style="font-weight: bold; color: #444;">@dev.Name</span>
                        <span style="background: #88d8c0; color: white; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 0.8em; font-weight: bold;">
                            @dev.Games.Count
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div style="border: 2px solid #88d8c0; border-radius: 8px; background: white; overflow: hidden;">
        <div style="background: #88d8c0; padding: 15px;">
            <form method="get" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; align-items: flex-end;">
                <div>
                    <label style="font-weight: bold; color: white; display: block; margin-bottom: 5px;">Title:</label>
                    <input type="text" asp-for="TitleFilter" placeholder="Search..."
                           style="width: 100%; padding: 8px; border-radius: 20px; border: none; outline: none;" />
                </div>
                <div>
                    <label style="font-weight: bold; color: white; display: block; margin-bottom: 5px;">Genre:</label>
                    <select asp-for="SelectedGenre" asp-items="Model.Genres"
                            style="width: 100%; padding: 8px; border-radius: 20px; border: none; outline: none;">
                        <option value="">All Genres</option>
                    </select>
                </div>
                <div>
                    <label style="font-weight: bold; color: white; display: block; margin-bottom: 5px;">Since Year:</label>
                    <input type="number" asp-for="MinYear" placeholder="Year"
                           style="width: 100%; padding: 8px; border-radius: 20px; border: none; outline: none;" />
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="submit" style="background: #444; color: white; border: none; padding: 8px 15px; border-radius: 20px; cursor: pointer; flex-grow: 1;">
                        Filter
                    </button>
                    <a href="/Stats/Index" style="background: white; color: #444; text-decoration: none; padding: 8px 15px; border-radius: 20px; text-align: center;">Clear</a>
                </div>
            </form>
        </div>

        <div style="padding: 20px;">
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 15px;">
                @foreach (var game in Model.FilteredByNameGames)
                {
                    <div style="padding: 15px; border: 1px solid #eee; border-radius: 8px; text-align: center;">
                        <div style="font-weight: bold; color: #444;">@game.Title</div>
                        <div style="color: #999; font-size: 12px;">@game.Genre | @game.Year</div>
                        <div style="color: #88d8c0; font-size: 14px; margin-top: 5px; font-weight: bold;">★ @game.Score</div>
                    </div>
                }
            </div>
            @if (!Model.FilteredByNameGames.Any())
            {
                <p style="text-align: center; color: #999;">No games match your search criteria.</p>
            }
        </div>
    </div>
</div>