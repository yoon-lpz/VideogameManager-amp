@page "{id:int}"
@model VideoGameManager.Pages.Games.DeleteModel
@{
    ViewData["Title"] = $"Delete {Model.Game?.Title}";
}

<div style="font-family: 'Segoe UI'; max-width: 600px; margin: 30px auto">
    
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div style="background-color: #f8d7da; color: #721c24; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #f5c6cb;">
            @Model.ErrorMessage
        </div>
    }

    <div style="border: 2px solid #e74c3c; border-radius: 8px; background-color: white;">

        <div style="background-color: #e74c3c; padding: 10px 20px; display: flex; align-items: center; justify-content: center;">
            <span style="color: white; font-weight: bold; font-size: 16px; letter-spacing: 4px;">
                DELETE
            </span>
        </div>

        <div style="padding: 25px;">
            <h1 style="margin: 0 0 20px 0; color: #444; border-bottom: 1px solid #eee; padding-bottom: 10px; font-size: 32px;">
                @Model.Game?.Title
            </h1>

            <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                <tr>
                    <td style="padding: 8px 0; color: #e74c3c; font-weight: bold; width: 30%; font-size: 15px;">Genre</td>
                    <td style="padding: 8px 0; font-size: 15px;">@Model.Game?.Genre</td>
                </tr>
                <tr>
                    <td style="padding: 8px 0; color: #e74c3c; font-weight: bold; font-size: 15px;">Year</td>
                    <td style="padding: 8px 0; font-size: 15px;">@Model.Game?.Year</td>
                </tr>
                <tr>
                    <td style="padding: 8px 0; color: #e74c3c; font-weight: bold; vertical-align: top; font-size: 15px;">Description</td>
                    <td style="padding: 8px 0; color: #666; line-height: 1.4; font-size: 15px;">
                        @(string.IsNullOrWhiteSpace(Model.Game?.Description) ? "No description." : Model.Game.Description)
                    </td>
                </tr>
            </table>

            <div style="background-color: #f4fbf9; padding: 15px; border-radius: 4px; display: flex; justify-content: space-between; align-items: center;">
                <span style="font-weight: bold; color: #555; font-size: 15px;">Score</span>
                <div>
                    @for (int i = 0; i < Model.FilledStars; i++)
                    {
                        <span style="color: #88d8c0; font-size: 24px;">★</span>
                    }
                    @for (int i = 0; i < Model.EmptyStars; i++)
                    {
                        <span style="color: #ddd; font-size: 24px;">☆</span>
                    }
                    <strong style="margin-left: 10px; font-size: 18px;">@Model.Game?.Score</strong>
                </div>
            </div>

            <div style="margin-top: 25px; text-align: center;">
                @* El ID se pasa a través de la URL de la página, pero el form debe ser post *@
                <form method="post">
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 10px;">
                        <a asp-page="./Details" asp-route-id="@Model.Game?.Id" style="text-decoration: none; color: #88d8c0; font-size: 14px; border: 1px solid #88d8c0; padding: 8px 20px; border-radius: 20px; font-weight: bold; display: inline-block;">
                            Cancel
                        </a>
                        <button type="submit" style="background-color: #e74c3c; color: white; border: 1px solid #e74c3c; padding: 8px 25px; border-radius: 20px; font-weight: bold; font-size: 14px; cursor: pointer;">
                            Confirm Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>