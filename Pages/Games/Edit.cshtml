@page "{id:int}"
@model VideoGameManager.Pages.Games.EditModel
@{
	ViewData["Title"] = $"Edit {Model.Game.Title}";
}

<div style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 600px; margin: 30px auto; border: 2px solid #88d8c0; border-radius: 8px; overflow: hidden; background-color: white;">
    
    <div style="background-color: #88d8c0; padding: 10px 20px; display: flex; align-items: center; justify-content: center;">
        <span style="color: white; font-weight: bold; font-size: 16px; letter-spacing: 4px;">
            EDITING @Model.Game.Title
        </span>
    </div>

    <form method="post" style="padding: 25px;">
        <div asp-validation-summary="ModelOnly" style="color: #e74c3c; margin-bottom: 15px; font-size: 15px;"></div>

        <input type="hidden" asp-for="Game.Id" />

        <div style="margin-bottom: 20px;">
            <label asp-for="Game.Title" style="display: block; font-weight: bold; color: #88d8c0; margin-bottom: 8px; font-size: 15px;">Title</label>
            <input asp-for="Game.Title" type="text" style="width: 100%; padding: 10px; border: 1px solid #eee; border-radius: 4px; box-sizing: border-box; font-size: 15px; outline-color: #88d8c0;" />
            <span asp-validation-for="Game.Title" style="color: #e74c3c; font-size: 12px;"></span>
        </div>

        <div style="display: flex; gap: 20px; margin-bottom: 20px;">
            <div style="flex: 1;">
                <label asp-for="Game.Genre" style="display: block; font-weight: bold; color: #88d8c0; margin-bottom: 8px; font-size: 15px;">Genre</label>
                <input asp-for="Game.Genre" type="text" style="width: 100%; padding: 10px; border: 1px solid #eee; border-radius: 4px; box-sizing: border-box; font-size: 15px; outline-color: #88d8c0;" />
                <span asp-validation-for="Game.Genre" style="color: #e74c3c; font-size: 12px;"></span>
            </div>
            <div style="flex: 1;">
                <label asp-for="Game.Year" style="display: block; font-weight: bold; color: #88d8c0; margin-bottom: 8px; font-size: 15px;">Year</label>
                <input asp-for="Game.Year" type="number" style="width: 100%; padding: 10px; border: 1px solid #eee; border-radius: 4px; box-sizing: border-box; font-size: 15px; outline-color: #88d8c0;" />
                <span asp-validation-for="Game.Year" style="color: #e74c3c; font-size: 12px;"></span>
            </div>
        </div>

        <div style="margin-bottom: 20px;">
            <label asp-for="Game.Description" style="display: block; font-weight: bold; color: #88d8c0; margin-bottom: 8px; font-size: 15px;">Description</label>
            <textarea asp-for="Game.Description" rows="3" style="width: 100%; padding: 10px; border: 1px solid #eee; border-radius: 4px; box-sizing: border-box; font-family: inherit; font-size: 15px; outline-color: #88d8c0;"></textarea>
        </div>

        <div style="background-color: #f4fbf9; padding: 15px; border-radius: 4px; margin-bottom: 25px;">
            <label asp-for="Game.Score" style="display: block; font-weight: bold; color: #555; margin-bottom: 8px; font-size: 15px;">Score (1-10)</label>
            <input asp-for="Game.Score" type="number" step="any" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; font-size: 15px; outline-color: #88d8c0;" />
            <span asp-validation-for="Game.Score" style="color: #e74c3c; font-size: 12px;"></span>
        </div>

        <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 10px;">
            <a asp-page="./Details" asp-route-id="@Model.Game.Id" style="text-decoration: none; color: #88d8c0; font-size: 14px; font-weight: bold; border: 1px solid #88d8c0; padding: 8px 20px; border-radius: 20px;">
                Cancel
            </a>
            <button type="submit" style="background-color: #88d8c0; color: white; border: 1px solid #88d8c0; padding: 8px 25px; border-radius: 20px; font-weight: bold; font-size: 14px; cursor: pointer;">
                Update game
            </button>
        </div>
    </form>
</div>
